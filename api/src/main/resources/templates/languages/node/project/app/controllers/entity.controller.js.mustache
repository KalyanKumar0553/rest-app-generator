const {{modelName}} = require('../models/{{modelName}}.model');

exports.create = async (req, res, next) => {
  try {
    const item = await {{modelName}}.create(req.body || {});
    res.status(201).json(item._id);
  } catch (e) {
    next(e);
  }
};

exports.list = async (req, res, next) => {
  try {
    const data = await {{modelName}}.find(req.query || {}).lean();
    res.json(data);
  } catch (e) {
    next(e);
  }
};

exports.getById = async (req, res, next) => {
  try {
    const item = await {{modelName}}.findById(req.params.id).lean();
    if (!item) {
      return res.status(404).json({ message: '{{modelName}} not found' });
    }
    res.json(item);
  } catch (e) {
    next(e);
  }
};

exports.patch = async (req, res, next) => {
  try {
    const item = await {{modelName}}.findByIdAndUpdate(req.params.id, req.body || {}, { new: true }).lean();
    if (!item) {
      return res.status(404).json({ message: '{{modelName}} not found' });
    }
    res.json(item);
  } catch (e) {
    next(e);
  }
};

exports.remove = async (req, res, next) => {
  try {
    const deleted = await {{modelName}}.findByIdAndDelete(req.params.id).lean();
    if (!deleted) {
      return res.status(404).json({ message: '{{modelName}} not found' });
    }
    res.json(deleted._id);
  } catch (e) {
    next(e);
  }
};
