    private static <T> List<List<T>> partition(List<T> source, int requestedBatchSize) {
        int batchSize = Math.max(1, requestedBatchSize);
        if (source == null || source.isEmpty()) {
            return List.of();
        }
        List<List<T>> batches = new ArrayList<>();
        for (int index = 0; index < source.size(); index += batchSize) {
            int end = Math.min(source.size(), index + batchSize);
            batches.add(new ArrayList<>(source.subList(index, end)));
        }
        return batches;
    }

