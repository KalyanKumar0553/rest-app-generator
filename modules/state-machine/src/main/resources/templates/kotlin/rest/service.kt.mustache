    private fun validateBulkUpdateTargets(requests: List<{{entityName}}>) {
        requests.firstOrNull { !repository.existsById(extractId(it)) }
            ?.let { throw ResponseStatusException(HttpStatus.NOT_FOUND, "{{entityName}} not found for id: ${extractId(it)}") }
    }

