    private fun dedupeById(requests: List<{{entityName}}>): List<{{entityName}}> {
        val unique = linkedMapOf<{{idType}}, {{entityName}}>()
        requests.forEach { request ->
            val id = extractId(request)
            if (!unique.containsKey(id)) {
                unique[id] = request
            }
        }
        return unique.values.toList()
    }

    private fun extractId(request: {{entityName}}): {{idType}} {
        val id = request.{{idName}}
        if (id == null) {
            throw ResponseStatusException(HttpStatus.BAD_REQUEST, "{{idName}} is required for bulk update")
        }
        return id
    }

    private fun <T> partition(source: List<T>, requestedBatchSize: Int): List<List<T>> {
        if (source.isEmpty()) {
            return emptyList()
        }
        val batchSize = requestedBatchSize.coerceAtLeast(1)
        val out = mutableListOf<List<T>>()
        var index = 0
        while (index < source.size) {
            val end = (index + batchSize).coerceAtMost(source.size)
            out.add(source.subList(index, end))
            index = end
        }
        return out
    }
